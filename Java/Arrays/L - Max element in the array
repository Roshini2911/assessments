Find maximum element from the given array of integers.


import java.util.Scanner;
class Main{
    public static void main (String[] args) {
        Scanner c=new Scanner(System.in);
        int N=c.nextInt();
        int[] arr=new int[N];
        for(int i=0;i<N;i++){
            arr[i]=c.nextInt();
        }
        int max=arr[0];
        for(int j=0;j<N;j++){
            if(arr[j]>max){
                max=arr[j];
            }
        }
        System.out.println(max);
    }
}
